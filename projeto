///////////////interações DO JS
// Executado quando a página termina de carregar completamente
document.addEventListener("DOMContentLoaded", () => {
    // Exemplo de Interação 1: Alerta amigável de Boas-vindas (Apenas na Home)
    if (window.location.pathname.includes("index.html") || window.location.pathname === "/") {
        console.log("Portfólio Mittmann carregado com sucesso!");
    }


    // Monitora a rolagem da página para exibir o botão de voltar ao topo
    window.onscroll = function() {
        configurarBotaoTopo();
    };
});


// Exemplo de Interação 2: Botão Voltar ao Topo dinâmico
function configurarBotaoTopo() {
    const btn = document.getElementById("btnVoltarTopo");
    if (btn) {
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
            btn.style.display = "block";
        } else {
            btn.style.display = "none";
        }
    }
}


function voltarAoTopo() {
    window.scrollTo({
        top: 0,
        behavior: 'smooth' // Rolagem suave elegante
    });
}


// Exemplo de Interação 3: Validação Simples do Formulário de Contato (Campos Obrigatórios)
function validarFormulario(event) {
    // Impede o envio real do formulário para podermos validar antes
    event.preventDefault();


    const nome = document.getElementById("nome").value.trim();
    const email = document.getElementById("email").value.trim();
    const assunto = document.getElementById("assunto").value.trim();
    const mensagem = document.getElementById("mensagem").value.trim();


    // Verificação se algum campo está em branco
    if (nome === "" || email === "" || assunto === "" || mensagem === "") {
        alert("⚠️ Por favor, preencha todos os campos obrigatórios do formulário.");
        return false;
    }


    // Se passou na validação
    alert(`Olá, ${nome}! Sua mensagem sobre "${assunto}" foi simulada com sucesso. (Requisito JS Validado!)`);
    document.getElementById("formContato").reset(); // Limpa os campos
    return true;
}
