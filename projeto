// Aguarda o DOM carregar
document.addEventListener("DOMContentLoaded", () => {
    const botao = document.getElementById("btn-contato");
    const textoContato = document.getElementById("info-contato");


    botao.addEventListener("click", () => {
        if (textoContato.style.display === "none") {
            textoContato.style.display = "block";
            botao.textContent = "Esconder e-mail";
        } else {
            textoContato.style.display = "none";
            botao.textContent = "Clique para ver o e-mail";
        }
    });
});
